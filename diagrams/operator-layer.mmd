flowchart TB
    UI["AI Surfaces<br/>Voice shell, chat, overlays, automation UI, ambient assist"] --> SDK["AI Framework APIs / SDK<br/>Agent API, tool API, memory API, policy API"]
    SDK --> AISVC["AI System Services<br/>Agent manager, memory manager, model router, policy engine, capability broker, audit log"]
    SDK --> APPS["Apps + Plugins<br/>AI-native apps, extensions, automations"]

    APPS --> FW["Android Framework APIs"]
    UI --> FW
    FW --> SS["System Server"]

    AISVC --> SS
    AISVC --> NATIVE["Native AI / System Components<br/>Local inference runtime, vector store, indexing, speech, notification parsing"]
    AISVC --> HAL["HAL / Vendor Services<br/>Camera, mic, sensors, radio, biometrics, NNAPI / accelerators"]

    SS --> ART["ART + Zygote"]
    SS --> CORE["Core Native Services<br/>SurfaceFlinger, media, audio, netd, vold, keystore"]
    NATIVE --> CORE
    CORE --> HAL
    HAL --> K["Linux Kernel"]
    ART --> K
